# OpenClaw Monitor 配置文件

# 代理配置
PROXY_PORT=38080
TARGET_URL=https://api.lkeap.cloud.tencent.com/coding/v3
LOG_DIR=/var/log/openclaw-monitor
LOG_ROTATION_DAYS=7

# 重试配置
MAX_RETRIES=3
RETRY_DELAY=1000

# 连接池配置
KEEP_ALIVE=true
MAX_SOCKETS=50
MAX_FREE_SOCKETS=10
TIMEOUT=30000

# 日志配置
LOG_SENSITIVE_DATA=false

# 后端配置
BACKEND_PORT=3000
OPENCLAW_DIR=/root/.openclaw
CACHE_TTL=30000

# 安全配置（必须配置）
API_TOKEN=your-random-token-here

# CORS 配置（生产环境必须限制）
# 多个源用逗号分隔，如：http://localhost:5173,https://example.com
CORS_ORIGIN=

# IP 白名单（可选）
# 多个 IP 用逗号分隔，支持 CIDR，如：192.168.1.0/24,10.0.0.1
IP_WHITELIST=

# 速率限制（可选）
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=100

# HTTPS 配置（可选）
HTTPS_ENABLED=false
HTTPS_KEY=/etc/openclaw-monitor/key.pem
HTTPS_CERT=/etc/openclaw-monitor/cert.pem

# 健康检查配置
HEALTHCHECK_INTERVAL=60
HEALTHCHECK_COOLDOWN=300
